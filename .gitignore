# ==========================================
# Python 核心缓存与字节码
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
coverage.xml
.cache/
nosetests.xml

# ==========================================
# 虚拟环境 (防止上传几百MB的库文件)
# ==========================================
venv/
env/
.venv/
.conda/
pip-log.txt
pip-delete-this-directory.txt

# ==========================================
# 项目输出结果 (仅保留结构，忽略数据)
# ==========================================
# 忽略所有生成的分析数据、模型和图表
output/models/*
output/results/*
output/visualizations/*

# 允许追踪每个输出目录下的 .gitkeep 文件（用于保持空文件夹结构）
!output/**/.gitkeep

# 忽略日志
logs/*.log
logs/

# ==========================================
# 数据文件 (保护隐私 & 防止大文件上传)
# ==========================================
# 忽略原始数据集
data/*.xlsx
data/*.csv
data/processed/

# 如果你有特定的 demo 数据需要上传，请取消下面这行的注释
# !data/demo_data.csv

# ==========================================
# IDE、编辑器与系统垃圾
# ==========================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
.DS_Store?
Thumbs.db
.ipynb_checkpoints/

# ==========================================
# 环境配置与敏感信息
# ==========================================
.env
.env.local
*.tmp
*.temp